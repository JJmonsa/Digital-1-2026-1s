:vpi_module "/home/digital/miniconda3/envs/digital/lib/ivl/va_math.vpi";
S_0xc9931e0 .scope module, "Subtractor_TB" "Subtractor_TB" 2 1;
 .timescale 0 0;
v0xc9e0060_0 .net "Neg", 0 0, L_0xc9e03c0;  1 drivers
v0xc9e0120_0 .var "RAC", 15 0;
v0xc9e01f0_0 .net "SUM", 16 0, v0xc9dfe10_0;  1 drivers
v0xc9e02f0_0 .var "Temp", 7 0;
S_0xc993370 .scope module, "uut" "Subtractor" 2 6, 3 1 0, S_0xc9931e0;
 .timescale 0 0;
    .port_info 0 /INPUT 16 "RAC";
    .port_info 1 /INPUT 8 "Temp";
    .port_info 2 /OUTPUT 17 "SUM";
    .port_info 3 /OUTPUT 1 "Neg";
v0xc993550_0 .net "Neg", 0 0, L_0xc9e03c0;  alias, 1 drivers
v0xc9dfd30_0 .net "RAC", 15 0, v0xc9e0120_0;  1 drivers
v0xc9dfe10_0 .var "SUM", 16 0;
v0xc9dfed0_0 .net "Temp", 7 0, v0xc9e02f0_0;  1 drivers
E_0xc9cf070 .event anyedge, v0xc9dfd30_0, v0xc9dfed0_0;
L_0xc9e03c0 .part v0xc9dfe10_0, 16, 1;
    .scope S_0xc993370;
T_0 ;
    %wait E_0xc9cf070;
    %load/vec4 v0xc9dfd30_0;
    %pad/u 17;
    %pushi/vec4 0, 0, 8;
    %load/vec4 v0xc9dfed0_0;
    %parti/s 7, 0, 2;
    %concat/vec4; draw_concat_vec4
    %concati/vec4 1, 0, 1;
    %pad/u 17;
    %sub;
    %store/vec4 v0xc9dfe10_0, 0, 17;
    %jmp T_0;
