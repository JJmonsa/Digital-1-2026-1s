    %pushi/vec4 4, 0, 8;
    %store/vec4 v0xc9e02f0_0, 0, 8;
    %delay 40, 0;
    %pushi/vec4 20, 0, 16;
    %store/vec4 v0xc9e0120_0, 0, 16;
    %pushi/vec4 4, 0, 8;
    %store/vec4 v0xc9e02f0_0, 0, 8;
    %delay 40, 0;
    %pushi/vec4 100, 0, 16;
    %store/vec4 v0xc9e0120_0, 0, 16;
    %pushi/vec4 15, 0, 8;
    %store/vec4 v0xc9e02f0_0, 0, 8;
    %delay 40, 0;
    %pushi/vec4 0, 0, 16;
    %store/vec4 v0xc9e0120_0, 0, 16;
    %pushi/vec4 0, 0, 8;
    %store/vec4 v0xc9e02f0_0, 0, 8;
    %delay 40, 0;
    %vpi_call 2 24 "$finish" {0 0 0};
    %end;
    .thread T_1;
