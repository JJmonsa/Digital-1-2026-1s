    .scope S_0xc9931e0;
T_1 ;
    %vpi_call 2 9 "$dumpfile", "Subtractor_TB.vcd" {0 0 0};
    %vpi_call 2 10 "$dumpvars", 32'sb00000000000000000000000000000000, S_0xc9931e0 {0 0 0};
    %pushi/vec4 14, 0, 16;
